{
  "name": "hiring-agent",
  "private": true,
  "packageManager": "pnpm@9.0.0",
  "type": "module",
  "scripts": {
    "dev:candidate-chatbot": "node services/candidate-chatbot/src/index.js",
    "dev:hiring-agent": "APP_MODE=${APP_MODE:-demo} node services/hiring-agent/src/cli.js",
    "deploy:sandbox": "APP_ENV=sandbox SECRET_PROFILE=sandbox EXTRA_ENV_VARS=HH_USE_MOCK=true SERVICE=candidate-chatbot-sandbox DB_SECRET_ENV=DATABASE_URL DB_SECRET_NAME=SANDBOX_DATABASE_URL DEPLOY_PUBLIC_URL=${SANDBOX_URL:?SANDBOX_URL is required for deploy:sandbox} bash ./scripts/deploy.sh",
    "test": "node --test tests/integration/candidate-chatbot.test.js",
    "test:postgres": "node --test tests/integration/candidate-chatbot-postgres.test.js",
    "test:unit": "node --test tests/unit/prompt-builder.test.js tests/unit/cta-validator.test.js",
    "test:hiring-agent": "node --test tests/unit/hiring-agent-router.test.js tests/unit/hiring-agent-funnel-query.test.js tests/unit/hiring-agent-auth.test.js tests/unit/hiring-agent-runtime.test.js tests/unit/access-context.test.js tests/integration/hiring-agent.test.js tests/integration/hiring-agent-funnel-adapter.test.js tests/integration/access-context-postgres.test.js",
    "test:hh": "node --test tests/integration/hh-connector.test.js tests/integration/hh-api-client.test.js",
    "test:cron": "node --test tests/integration/cron-sender.test.js",
    "test:moderation": "node --test tests/integration/moderation-ui.test.js",
    "test:tenant": "node --test tests/integration/multi-tenant.test.js",
    "test:telegram": "node --test tests/integration/telegram-notifications.test.js",
    "migrate:management": "node scripts/migrate-management.js",
    "bootstrap:management:tenants": "node scripts/bootstrap-management-tenants.js",
    "bootstrap:management:recruiters": "node scripts/bootstrap-management-recruiters.js",
    "bootstrap:management:bindings": "node scripts/bootstrap-database-bindings.js",
    "check:management-readiness": "node scripts/check-management-readiness.js",
    "seed:dev": "node scripts/seed-dev-db.js",
    "seed:sandbox": "node scripts/seed-sandbox-db.js",
    "bootstrap:demo-user": "node scripts/bootstrap-demo-user.js",
    "bootstrap:recruiter-access": "node scripts/bootstrap-recruiter-access.js",
    "test:all": "node --test tests/**/*.test.js",
    "test:sandbox": "APP_ENV=sandbox HH_USE_MOCK=true pnpm test:all",
    "gate:sandbox": "pnpm test:sandbox && pnpm smoke:sandbox",
    "smoke:sandbox": "node scripts/smoke-sandbox.js",
    "smoke:sandbox:cloud": "BASE_URL=${SANDBOX_URL:?SANDBOX_URL is required for smoke:sandbox:cloud} node scripts/smoke-sandbox.js",
    "report:legacy": "node scripts/legacy-pipeline-report.js",
    "report:evaluation": "node scripts/generate-evaluation-report.js"
  },
  "workspaces": [
    "services/*",
    "packages/*"
  ],
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@neondatabase/serverless": "^1.0.2",
    "bcryptjs": "^3.0.3",
    "pg": "^8.20.0",
    "postgres": "^3.4.7"
  }
}
