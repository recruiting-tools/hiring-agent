{
  "name": "hiring-agent",
  "private": true,
  "packageManager": "pnpm@9.0.0",
  "type": "module",
  "scripts": {
    "dev:candidate-chatbot": "node services/candidate-chatbot/src/index.js",
    "deploy:sandbox": "APP_ENV=sandbox EXTERNAL_MODE=mock LLM_MODE=fake SECRET_PROFILE=sandbox SERVICE=candidate-chatbot-sandbox DB_SECRET_ENV=DATABASE_URL DB_SECRET_NAME=SANDBOX_DATABASE_URL DEPLOY_PUBLIC_URL=${SANDBOX_URL:-https://candidate-chatbot-sandbox-<something>.a.run.app} bash ./scripts/deploy.sh",
    "test": "node --test tests/integration/candidate-chatbot.test.js",
    "test:postgres": "node --test tests/integration/candidate-chatbot-postgres.test.js",
    "test:unit": "node --test tests/unit/prompt-builder.test.js",
    "test:hh": "node --test tests/integration/hh-connector.test.js tests/integration/hh-api-client.test.js",
    "test:cron": "node --test tests/integration/cron-sender.test.js",
    "test:moderation": "node --test tests/integration/moderation-ui.test.js",
    "test:tenant": "node --test tests/integration/multi-tenant.test.js",
    "test:telegram": "node --test tests/integration/telegram-notifications.test.js",
    "seed:dev": "node scripts/seed-dev-db.js",
    "seed:sandbox": "node scripts/seed-sandbox-db.js",
    "bootstrap:demo-user": "node scripts/bootstrap-demo-user.js",
    "test:all": "node --test tests/**/*.test.js",
    "test:sandbox": "pnpm test:moderation && pnpm test:hh && pnpm test:cron && pnpm test:tenant",
    "smoke:sandbox": "node scripts/smoke-sandbox.js",
    "smoke:sandbox:cloud": "BASE_URL=${SANDBOX_URL:-https://candidate-chatbot-sandbox-<something>.a.run.app} node scripts/smoke-sandbox.js",
    "report:legacy": "node scripts/legacy-pipeline-report.js",
    "report:evaluation": "node scripts/generate-evaluation-report.js"
  },
  "workspaces": [
    "services/*",
    "packages/*"
  ],
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@neondatabase/serverless": "^1.0.2",
    "bcryptjs": "^3.0.3",
    "pg": "^8.20.0"
  }
}
