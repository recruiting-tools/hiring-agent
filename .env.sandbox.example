APP_ENV=sandbox
EXTERNAL_MODE=mock
LLM_MODE=fake

SANDBOX_BASE_URL=http://localhost:3000
# DATABASE_URL is for local sandbox dev; fetch the real password via neonctl or the Neon console and do not commit it.
DATABASE_URL=postgres://user:<fetch-from-neonctl-or-neon-console>@ep-your-sandbox-branch-pooler.region.aws.neon.tech/dbname?sslmode=require
# SANDBOX_DATABASE_URL is the GCP Secret Manager secret name mounted into Cloud Run as DATABASE_URL.
SANDBOX_DATABASE_URL=SANDBOX_DATABASE_URL
SANDBOX_RESET=1

SANDBOX_DEMO_EMAIL=demo@hiring-agent.app
SANDBOX_DEMO_PASSWORD=change-me
SANDBOX_DEMO_RECRUITER_ID=recruiter-demo-001
SANDBOX_DEMO_RECRUITER_TOKEN=rec-tok-demo-001
DEPLOY_SHA=local
SEED_VERSION=local
