APP_ENV=sandbox
EXTERNAL_MODE=mock
LLM_MODE=fake

SANDBOX_BASE_URL=http://localhost:3000
# tenant data-plane DB for sandbox recruiter data, jobs, candidates
CHATBOT_DATABASE_URL=postgres://user:<fetch-from-neonctl-or-neon-console>@ep-your-sandbox-branch-pooler.region.aws.neon.tech/dbname?sslmode=require
# control-plane DB for sandbox recruiters, sessions, playbooks, bindings
MANAGEMENT_DATABASE_URL=postgres://user:<fetch-from-neonctl-or-neon-console>@ep-your-management-sandbox-branch-pooler.region.aws.neon.tech/dbname?sslmode=require
# DATABASE_URL kept only as a convenience alias for scripts that still expect it
DATABASE_URL=${CHATBOT_DATABASE_URL}
# SANDBOX_DATABASE_URL is the GCP Secret Manager secret name mounted into Cloud Run as DATABASE_URL.
SANDBOX_DATABASE_URL=SANDBOX_DATABASE_URL
SANDBOX_RESET=1

SANDBOX_DEMO_EMAIL=demo@hiring-agent.app
SANDBOX_DEMO_PASSWORD=change-me
SANDBOX_DEMO_RECRUITER_ID=recruiter-demo-001
SANDBOX_DEMO_RECRUITER_TOKEN=rec-tok-demo-001
DEPLOY_SHA=local
SEED_VERSION=local
